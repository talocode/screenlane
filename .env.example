# Copy to .env locally — never commit real keys

# ── Access control + Talocode cloud (ONLY this key) ──────────────────────────
# When SCREENLANE_REQUIRE_AUTH=true:
#   Authorization: Bearer <TALOCODE_API_KEY>
# Also used for Tera / Codra / GateLane HTTP calls.
# Do NOT use SCREENLANE_API_KEY, TERA_API_KEY, CODRA_API_KEY, or GATELANE_API_KEY.
TALOCODE_API_KEY=

# Gate local HTTP API (default: open on localhost)
SCREENLANE_REQUIRE_AUTH=false

# Optional service base URLs (integrations are real HTTP calls, not faked)
TERA_API_BASE_URL=
CODRA_API_BASE_URL=
GATELANE_API_BASE_URL=
SCREENLANE_API_BASE_URL=

# Optional third-party audio transcription only (NOT used for ScreenLane access)
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

SCREENLANE_PORT=3070
SCREENLANE_HOME=
