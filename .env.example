# Copy to .env locally — never commit real keys

# Access control when SCREENLANE_REQUIRE_AUTH=true (ONLY this key is used)
TALOCODE_API_KEY=

# Gate local HTTP API
SCREENLANE_REQUIRE_AUTH=false

# Optional service endpoints (integrations are real HTTP calls, not faked)
TERA_API_BASE_URL=
TERA_API_KEY=
CODRA_API_BASE_URL=
CODRA_API_KEY=
GATELANE_API_BASE_URL=
GATELANE_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE_URL=

SCREENLANE_PORT=3070
SCREENLANE_HOME=
